<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Download Tiger Teams</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      text-align: center;
      padding: 40px 20px;
      line-height: 1.5;
    }
    .btn {
      display: inline-block;
      margin: 10px;
      padding: 12px 20px;
      text-decoration: none;
      border: 1px solid #ccc;
      border-radius: 8px;
      color: black;
    }
  </style>
  <script>
    function redirectUser() {
      const ua = navigator.userAgent || navigator.vendor || window.opera;
      const appStoreUrl = "https://apps.apple.com/us/app/tiger-teams/id6615087707";
      const playStoreUrl = "https://play.google.com/store/apps/details?id=com.fnoex.fan.hscasanluisobispo&hl=en_US";

      if (/android/i.test(ua)) {
        window.location.replace(playStoreUrl);
      } else if (/iPad|iPhone|iPod/.test(ua) && !window.MSStream) {
        window.location.replace(appStoreUrl);
      }
    }

    window.onload = function () {
      setTimeout(redirectUser, 300);
    };
  </script>
</head>
<body>
  <h1>Download Tiger Teams</h1>
  <p>Taking you to the right app store now.</p>
  <p>If nothing happens, choose your device below.</p>

  <a class="btn" href="https://apps.apple.com/us/app/tiger-teams/id6615087707">Download on iPhone</a>
  <a class="btn" href="https://play.google.com/store/apps/details?id=com.fnoex.fan.hscasanluisobispo&hl=en_US">Download on Android</a>
</body>
</html>
